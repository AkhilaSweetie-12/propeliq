# =============================================================================
# PropelIQ Infrastructure — Example Variable Values
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

# --- Required ---
project_id = "my-gcp-project-id"
github_org = "my-github-org"

# --- Optional overrides ---
# region             = "us-central1"
# zone               = "us-central1-a"
# environment        = "production"
# app_name           = "propeliq"
# cluster_name       = "propeliq-cluster"

# --- Networking ---
# network_name       = "propeliq-vpc"
# subnet_cidr        = "10.0.0.0/20"
# pods_cidr          = "10.4.0.0/14"
# services_cidr      = "10.8.0.0/20"

# --- GKE ---
# gke_version        = "REGULAR"
# node_machine_type  = "e2-standard-4"
# node_count         = 2
# node_min_count     = 1
# node_max_count     = 5
# enable_private_nodes = true

# master_authorized_networks = [
#   { cidr_block = "203.0.113.0/24", display_name = "Office" }
# ]

# --- Secrets ---
# create_artifactory_secrets = false
# create_consul_secrets      = false

# --- DNS / Load Balancer ---
# domain                     = "app.example.com"
# enable_managed_certificate = false

# --- Labels ---
# labels = {
#   team    = "platform"
#   product = "propeliq"
# }
