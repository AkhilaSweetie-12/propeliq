# Renovate Environment Configuration Template
# Copy this file to .env and update with your values

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# GitHub Personal Access Token (required)
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, read:org, read:user, user:email
RENOVATE_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Repository to process (if not using autodiscover)
# Format: username/repository
RENOVATE_REPOSITORY=

# =============================================================================
# PLATFORM CONFIGURATION
# =============================================================================

# Platform (usually github)
RENOVATE_PLATFORM=github

# GitHub API endpoint
RENOVATE_ENDPOINT=https://api.github.com

# =============================================================================
# GIT CONFIGURATION
# =============================================================================

# Git username for commits
RENOVATE_USERNAME=renovate[bot]

# Git author for commits
RENOVATE_GIT_AUTHOR=renovate[bot] <29139614+renovate[bot]@users.noreply.github.com>

# Optional: SSH private key for git operations
# Generate with: ssh-keygen -t ed25519 -C "renovate"
# Add to GitHub as deploy key
RENOVATE_GIT_PRIVATE_KEY=

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: error, warn, info, debug
RENOVATE_LOG_LEVEL=info

# Global log level
LOG_LEVEL=info

# Log file location
RENOVATE_LOG_FILE=/tmp/renovate.log

# Log file level
RENOVATE_LOG_FILE_LEVEL=debug

# =============================================================================
# REPOSITORY CONFIGURATION
# =============================================================================

# Enable autodiscovery of repositories
RENOVATE_AUTODISCOVER=true

# Filter for autodiscovery (optional)
# Example: "my-org/*" or "my-org/project-*"
RENOVATE_AUTODISCOVER_FILTER=

# Additional repositories to process (comma-separated)
RENOVATE_REPOSITORIES=

# Configuration file path
RENOVATE_CONFIG_FILE=renovate.json

# =============================================================================
# ONBOARDING CONFIGURATION
# =============================================================================

# Enable onboarding PR for new repositories
RENOVATE_ONBOARDING=false

# Require configuration file to run
RENOVATE_REQUIRE_CONFIG=false

# =============================================================================
# DASHBOARD CONFIGURATION
# =============================================================================

# Enable dependency dashboard
RENOVATE_DEPENDENCY_DASHBOARD=true

# Dashboard PR title
RENOVATE_DEPENDENCY_DASHBOARD_TITLE=Renovate Dashboard

# Dashboard labels (comma-separated)
RENOVATE_DEPENDENCY_DASHBOARD_LABELS=renovate,dependencies

# =============================================================================
# PULL REQUEST MANAGEMENT
# =============================================================================

# Maximum concurrent PRs
RENOVATE_PR_CONCURRENT_LIMIT=10

# Maximum PRs per hour
RENOVATE_PR_HOURLY_LIMIT=2

# Maximum concurrent branches
RENOVATE_BRANCH_CONCURRENT_LIMIT=10

# Branch name prefix
RENOVATE_BRANCH_PREFIX=renovate/

# When to rebase PRs
RENOVATE_REBASE_WHEN=auto

# Rebase label
RENOVATE_REBASE_LABEL=renovate/rebase

# Stop updating label
RENOVATE_STOP_UPDATING_LABEL=renovate/stop-updating

# =============================================================================
# LABELS AND ASSIGNEES
# =============================================================================

# Default labels for PRs (comma-separated)
RENOVATE_LABELS=renovate,dependencies

# Default assignees for PRs (comma-separated, GitHub usernames)
RENOVATE_ASSIGNEES=

# Default reviewers for PRs (comma-separated, GitHub usernames)
RENOVATE_REVIEWERS=

# =============================================================================
# SCHEDULING CONFIGURATION
# =============================================================================

# Schedule for running Renovate
RENOVATE_SCHEDULE=before 6am on monday

# Timezone for scheduling
RENOVATE_TIMEZONE=UTC

# =============================================================================
# SEMANTIC COMMITS
# =============================================================================

# Enable semantic commits
RENOVATE_SEMANTIC_COMMITS=enabled

# Semantic commit type
RENOVATE_SEMANTIC_COMMIT_TYPE=chore

# Semantic commit scope
RENOVATE_SEMANTIC_COMMIT_SCOPE=deps

# =============================================================================
# POST-UPDATE OPTIONS
# =============================================================================

# Post-update operations (comma-separated)
RENOVATE_POST_UPDATE_OPTIONS=gomodTidy,npmDedupe,yarnDedupe

# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Suppress notifications (comma-separated)
# Options: artifactErrors, branchAutomergeFailure, configErrorIssue, 
# dependencyLookupWarnings, lockFileErrors, missingCredentialsError,
# onboardingClose, prEditedNotification, prIgnoreNotification
RENOVATE_SUPPRESS_NOTIFICATIONS=prEdited

# =============================================================================
# AUTOMATION SETTINGS
# =============================================================================

# Enable automerge for Docker dependencies
RENOVATE_AUTOMERGE_DOCKER=true

# Enable automerge for Node.js dependencies
RENOVATE_AUTOMERGE_NODEJS=true

# Enable automerge for Python dependencies
RENOVATE_AUTOMERGE_PYTHON=true

# Enable automerge for Terraform modules
RENOVATE_AUTOMERGE_TERRAFORM=true

# Enable automerge for security updates
RENOVATE_AUTOMERGE_SECURITY=true

# Enable automerge for development dependencies
RENOVATE_AUTOMERGE_DEV_DEPS=true

# =============================================================================
# RELEASE AGE SETTINGS
# =============================================================================

# Minimum release age for Docker dependencies
RENOVATE_MIN_RELEASE_AGE_DOCKER=7 days

# Minimum release age for Node.js dependencies
RENOVATE_MIN_RELEASE_AGE_NODEJS=3 days

# Minimum release age for Python dependencies
RENOVATE_MIN_RELEASE_AGE_PYTHON=3 days

# Minimum release age for Terraform modules
RENOVATE_MIN_RELEASE_AGE_TERRAFORM=7 days

# Minimum release age for security updates
RENOVATE_MIN_RELEASE_AGE_SECURITY=1 day

# Minimum release age for development dependencies
RENOVATE_MIN_RELEASE_AGE_DEV_DEPS=3 days

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Enable vulnerability alerts
RENOVATE_VULNERABILITY_ALERTS=true

# Require dashboard approval for major updates
RENOVATE_MAJOR_DASHBOARD_APPROVAL=false

# Enable lockfile maintenance
RENOVATE_LOCKFILE_MAINTENANCE=true

# Enable automerge for lockfile updates
RENOVATE_AUTOMERGE_LOCKFILE=true

# Schedule for lockfile maintenance
RENOVATE_LOCKFILE_SCHEDULE=before 6am on the first day of the month

# =============================================================================
# PRIVATE REGISTRIES
# =============================================================================

# Host rules for private registries (JSON format)
# Example: '[{"hostType": "docker", "domain": "registry.example.com", "username": "user", "password": "pass"}]'
RENOVATE_HOST_RULES=

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Custom package rules (JSON format)
# Example: '[{"groupName": "Custom", "matchPackagePatterns": ["@company/*"], "automerge": true}]'
RENOVATE_CUSTOM_PACKAGE_RULES=

# Custom regex managers (JSON format)
# Example: '[{"fileMatch": ["*.custom"], "matchStrings": ["dep:\\s*(?<depName>[^:]+):(?<currentValue>.+)"]}]'
RENOVATE_CUSTOM_REGEX_MANAGERS=

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable dry run mode (no actual changes)
RENOVATE_DRY_RUN=false

# Force rebase of all PRs
RENOVATE_FORCE_REBASE=false

# Print configuration and exit
RENOVATE_PRINT_CONFIG=false

# Validate configuration and exit
RENOVATE_VALIDATE_CONFIG=false

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================

# Example for single repository:
# RENOVATE_REPOSITORY=myusername/myrepo
# RENOVATE_AUTODISCOVER=false

# Example for organization:
# RENOVATE_AUTODISCOVER=true
# RENOVATE_AUTODISCOVER_FILTER=my-org/*
# RENOVATE_TOKEN=github_pat_xxx (with org-level permissions)

# Example for private registry:
# RENOVATE_HOST_RULES='[{"hostType": "docker", "domain": "private-registry.com", "username": "myuser", "password": "mypass"}]'

# Example for custom scheduling:
# RENOVATE_SCHEDULE=every weekday
# RENOVATE_TIMEZONE=America/New_York
